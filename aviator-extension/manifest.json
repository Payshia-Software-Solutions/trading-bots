{
  "manifest_version": 3,
  "name": "Aviator Pattern Scraper & Sync",
  "version": "1.2",
  "description": "Scrapes Aviator round multipliers and shows real-time predictions in the Chrome Side Panel.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Aviator Predictor Side Panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
